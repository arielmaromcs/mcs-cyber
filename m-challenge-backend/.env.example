# ============================================================
# M-Challenge Security Scanner - Environment Configuration
# ============================================================

# Server
PORT=3001
HOST=0.0.0.0
NODE_ENV=development
LOG_LEVEL=info

# Database (PostgreSQL)
DATABASE_URL="postgresql://mchallenge:mchallenge@localhost:5432/mchallenge?schema=public"

# Redis (for BullMQ job queue)
REDIS_URL="redis://localhost:6379"

# JWT Auth
JWT_SECRET="change-this-to-a-long-random-secret-string"
JWT_EXPIRES_IN="7d"

# CORS
CORS_ORIGIN="http://localhost:3000"

# ---- External API Keys (optional - features degrade gracefully) ----

# NMAP Scanning Service
NMAP_API_URL="http://45.79.208.66:8888/nmap"
NMAP_API_KEY=""

# Shodan (port scanning / service banners)
SHODAN_API_KEY=""

# AbuseIPDB (IP reputation)
ABUSEIPDB_API_KEY=""

# WHOIS API
WHOIS_API_KEY=""

# ---- LLM Provider (for MITRE analysis + exploitability) ----
# Supports: openai, anthropic, local (stub)
LLM_PROVIDER="local"
LLM_API_KEY=""
LLM_MODEL="gpt-4o"
LLM_BASE_URL="https://api.openai.com/v1"

# ---- Email ----
# Provider: smtp | microsoft_graph
EMAIL_PROVIDER="smtp"

# SMTP
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_USER=""
SMTP_PASSWORD=""
SMTP_FROM_EMAIL="noreply@mchallenge.io"
SMTP_FROM_NAME="M-Challenge Scanner"

# Microsoft Graph (OAuth2 Client Credentials)
MS_TENANT_ID=""
MS_CLIENT_ID=""
MS_CLIENT_SECRET=""
MS_FROM_EMAIL=""

# ---- Stripe (subscription management) ----
STRIPE_SECRET_KEY=""
STRIPE_PUBLISHABLE_KEY=""
STRIPE_WEBHOOK_SECRET=""
STRIPE_PRO_PRICE_ID=""

# ---- File Storage ----
# Provider: local | s3
STORAGE_PROVIDER="local"
STORAGE_LOCAL_PATH="./uploads"
S3_BUCKET=""
S3_REGION=""
S3_ACCESS_KEY=""
S3_SECRET_KEY=""
S3_ENDPOINT=""

# ---- Rate Limiting ----
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_MS=60000

# ---- Guest Limits ----
GUEST_MAX_SCANS=5
